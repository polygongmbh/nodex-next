{
  "relayUrls": ["wss://one.example/", "wss://two.example/"],
  "events": [
    { "event": { "id": "m1", "pubkey": "alice", "kind": 1, "content": "kickoff #dev", "tags": [], "created_at": 100 }, "relayUrl": "wss://one.example/" },
    { "event": { "id": "m2", "pubkey": "bob", "kind": 1, "content": "reply #other", "tags": [["e", "m1", "", "parent"]], "created_at": 150 }, "relayUrl": "wss://one.example/" },
    { "event": { "id": "m5", "pubkey": "alice", "kind": 1, "content": "detail #sub", "tags": [["e", "m2", "", "parent"]], "created_at": 160 }, "relayUrl": "wss://one.example/" },
    { "event": { "id": "m6", "pubkey": "carol", "kind": 1, "content": "aside #sub", "tags": [["e", "m1", "", "parent"]], "created_at": 170 }, "relayUrl": "wss://one.example/" },
    { "event": { "id": "m3", "pubkey": "alice", "kind": 1, "content": "mockups #design", "tags": [["p", "bob"]], "created_at": 200 }, "relayUrl": "wss://one.example/" },
    { "event": { "id": "m4", "pubkey": "carol", "kind": 1, "content": "noise #random", "tags": [], "created_at": 250 }, "relayUrl": "wss://two.example/" },
    { "event": { "id": "t1", "pubkey": "alice", "kind": 1621, "content": "fix login #dev", "tags": [], "created_at": 300 }, "relayUrl": "wss://one.example/" },
    { "event": { "id": "s1", "pubkey": "bob", "kind": 1630, "content": "Review", "tags": [["e", "t1"]], "created_at": 400 }, "relayUrl": "wss://one.example/" }
  ],
  "scenarios": [
    {
      "name": "no filters shows everything oldest-first with state rows",
      "scope": {},
      "expected": [
        { "type": "post", "id": "m1" },
        { "type": "post", "id": "m2" },
        { "type": "post", "id": "m5" },
        { "type": "post", "id": "m6" },
        { "type": "post", "id": "m3" },
        { "type": "post", "id": "m4" },
        { "type": "post", "id": "t1" },
        { "type": "state", "id": "s1" }
      ]
    },
    {
      "name": "included channel is AND scoped",
      "scope": { "channelStates": { "dev": "included" } },
      "expected": [
        { "type": "post", "id": "m1" },
        { "type": "post", "id": "t1" },
        { "type": "state", "id": "s1" }
      ]
    },
    {
      "name": "excluded channel removes carriers only",
      "scope": { "channelStates": { "design": "excluded" } },
      "expected": [
        { "type": "post", "id": "m1" },
        { "type": "post", "id": "m2" },
        { "type": "post", "id": "m5" },
        { "type": "post", "id": "m6" },
        { "type": "post", "id": "m4" },
        { "type": "post", "id": "t1" },
        { "type": "state", "id": "s1" }
      ]
    },
    {
      "name": "pinned default scope is pinned channels plus mentions plus own posts",
      "scope": { "pinnedChannels": ["design"], "myPubkey": "bob" },
      "expected": [
        { "type": "post", "id": "m2" },
        { "type": "post", "id": "m3" }
      ]
    },
    {
      "name": "explicit include overrides the pinned default",
      "scope": { "pinnedChannels": ["design"], "myPubkey": "bob", "channelStates": { "random": "included" } },
      "expected": [{ "type": "post", "id": "m4" }]
    },
    {
      "name": "relay scope keeps only posts delivered by the active space",
      "scope": { "activeRelayId": "two-example" },
      "expected": [{ "type": "post", "id": "m4" }]
    },
    {
      "name": "search matches post content case-insensitively",
      "scope": { "searchQuery": "KICKOFF" },
      "expected": [{ "type": "post", "id": "m1" }]
    },
    {
      "name": "state rows match on their update label",
      "scope": { "searchQuery": "review" },
      "expected": [{ "type": "state", "id": "s1" }]
    },
    {
      "name": "root focus shows the whole conversation and bypasses channel scope",
      "scope": { "focusedPostId": "m1", "channelStates": { "design": "included" } },
      "expected": [
        { "type": "post", "id": "m1" },
        { "type": "post", "id": "m2" },
        { "type": "post", "id": "m5" },
        { "type": "post", "id": "m6" }
      ]
    },
    {
      "name": "nested focus scopes to the focused subtree plus ancestors, excluding sibling branches",
      "scope": { "focusedPostId": "m2" },
      "expected": [
        { "type": "post", "id": "m1" },
        { "type": "post", "id": "m2" },
        { "type": "post", "id": "m5" }
      ]
    },
    {
      "name": "a search matching nothing falls back to the unsearched feed",
      "scope": { "searchQuery": "no-such-token-anywhere" },
      "expected": [
        { "type": "post", "id": "m1" },
        { "type": "post", "id": "m2" },
        { "type": "post", "id": "m5" },
        { "type": "post", "id": "m6" },
        { "type": "post", "id": "m3" },
        { "type": "post", "id": "m4" },
        { "type": "post", "id": "t1" },
        { "type": "state", "id": "s1" }
      ]
    },
    {
      "name": "the search fallback is search-only: an empty relay scope stays empty",
      "scope": { "activeRelayId": "nonexistent-space", "searchQuery": "kickoff" },
      "expected": []
    }
  ],
  "calendarThread": {
    "events": [
      { "event": { "id": "c1", "pubkey": "alice", "kind": 31922, "content": "#team", "tags": [["d", "offsite"], ["title", "Offsite"], ["start", "2026-08-01"]], "created_at": 100 }, "relayUrl": "wss://one.example/" },
      { "event": { "id": "cm1", "pubkey": "bob", "kind": 1111, "content": "count me in #team", "tags": [["A", "31922:alice:offsite", ""], ["K", "31922"], ["P", "alice"], ["a", "31922:alice:offsite", ""], ["e", "c1", "", "alice"], ["k", "31922"], ["p", "alice"]], "created_at": 200 }, "relayUrl": "wss://one.example/" },
      { "event": { "id": "cm2", "pubkey": "carol", "kind": 1111, "content": "same #team", "tags": [["A", "31922:alice:offsite", ""], ["K", "31922"], ["P", "alice"], ["e", "cm1", "", "bob"], ["k", "1111"], ["p", "bob"]], "created_at": 300 }, "relayUrl": "wss://one.example/" },
      { "event": { "id": "m9", "pubkey": "alice", "kind": 1, "content": "noise #team", "tags": [], "created_at": 400 }, "relayUrl": "wss://one.example/" }
    ],
    "scenarios": [
      {
        "name": "focusing a calendar event shows it with its comment thread only",
        "scope": { "focusedPostId": "c1" },
        "expected": [
          { "type": "calendarEvent", "id": "c1" },
          { "type": "post", "id": "cm1" },
          { "type": "post", "id": "cm2" }
        ]
      },
      {
        "name": "focusing a comment keeps the calendar event as ancestor context",
        "scope": { "focusedPostId": "cm1" },
        "expected": [
          { "type": "calendarEvent", "id": "c1" },
          { "type": "post", "id": "cm1" },
          { "type": "post", "id": "cm2" }
        ]
      },
      {
        "name": "comments render as posts in the open feed",
        "scope": {},
        "expected": [
          { "type": "calendarEvent", "id": "c1" },
          { "type": "post", "id": "cm1" },
          { "type": "post", "id": "cm2" },
          { "type": "post", "id": "m9" }
        ]
      }
    ]
  }
}
