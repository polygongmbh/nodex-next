{
  "relays": [
    { "id": "one-example", "url": "wss://one.example/", "connected": true },
    { "id": "two-example", "url": "wss://two.example/", "connected": true },
    { "id": "three-example", "url": "wss://three.example/", "connected": false }
  ],
  "resolvePublishRelay": [
    { "name": "active space wins", "activeRelayId": "two-example", "expected": { "relayId": "two-example" } },
    { "name": "sole connected relay fallback", "relaySubset": ["one-example", "three-example"], "activeRelayId": null, "expected": { "relayId": "one-example" } },
    { "name": "ambiguous without selection errors", "activeRelayId": null, "expected": { "error": "error.selectSpace" } },
    { "name": "nothing connected errors", "relaySubset": ["three-example"], "activeRelayId": null, "expected": { "error": "error.noSpaceConnected" } },
    { "name": "unknown active space errors", "activeRelayId": "gone-example", "expected": { "error": "error.spaceUnavailable" } },
    { "name": "single candidate space auto-targets without selection", "activeRelayId": null, "channelSpaceIds": ["two-example"], "expected": { "relayId": "two-example" } },
    { "name": "channels spanning multiple spaces force selection", "activeRelayId": null, "channelSpaceIds": ["one-example", "two-example"], "expected": { "error": "error.selectSpace" } },
    { "name": "channel only on a disconnected space forces selection", "activeRelayId": null, "channelSpaceIds": ["three-example"], "expected": { "error": "error.selectSpace" } },
    { "name": "channel space is ignored when a space is actively selected", "activeRelayId": "one-example", "channelSpaceIds": ["two-example"], "expected": { "relayId": "one-example" } },
    { "name": "sole connected relay wins over channel spaces", "relaySubset": ["one-example", "three-example"], "activeRelayId": null, "channelSpaceIds": ["three-example"], "expected": { "relayId": "one-example" } },
    {
      "name": "reply pins to parent origin over active selection",
      "activeRelayId": "one-example",
      "parent": { "id": "root", "pubkey": "alice", "relays": ["two-example", "one-example"] },
      "expected": { "relayId": "two-example" }
    },
    {
      "name": "parent origin space unavailable errors",
      "activeRelayId": "one-example",
      "parent": { "id": "root", "pubkey": "alice", "relays": ["gone-example"] },
      "expected": { "error": "error.parentSpaceUnavailable" }
    }
  ],
  "buildMessageTags": [
    { "name": "channels become lowercased t-tags", "channels": ["General", "design"], "expected": { "tags": [["t", "general"], ["t", "design"]] } },
    { "name": "at least one channel required", "channels": [], "expected": { "error": "error.needChannel" } },
    {
      "name": "reply to the thread root uses a single NIP-10 root-marked e-tag",
      "channels": ["general"],
      "reply": {
        "parent": { "id": "root", "pubkey": "alice", "mentions": [] },
        "root": { "id": "root", "pubkey": "alice" }
      },
      "expected": { "tags": [["t", "general"], ["e", "root", "", "root", "alice"], ["p", "alice"]] }
    },
    {
      "name": "reply to a nested post carries root and reply e-tags plus thread p-tags",
      "channels": ["general"],
      "reply": {
        "parent": { "id": "mid", "pubkey": "bob", "mentions": ["alice", "carol"] },
        "root": { "id": "root", "pubkey": "alice" }
      },
      "expected": {
        "tags": [
          ["t", "general"],
          ["e", "root", "", "root", "alice"],
          ["e", "mid", "", "reply", "bob"],
          ["p", "bob"],
          ["p", "alice"],
          ["p", "carol"]
        ]
      }
    }
  ],
  "resolveDraftChannels": [
    { "name": "included chips union typed hashtags", "content": "ship #Launch today", "included": ["general"], "expected": ["general", "launch"] },
    { "name": "uppercase hex color in draft is not a channel", "content": "color #FFF", "included": [], "expected": [] }
  ],
  "buildReplyEvent": [
    {
      "name": "reply under a kind-1 root stays NIP-10 kind 1",
      "channels": ["general"],
      "reply": {
        "parent": { "id": "root", "pubkey": "alice", "kind": 1, "mentions": [] },
        "root": { "id": "root", "pubkey": "alice", "kind": 1 }
      },
      "expected": { "kind": 1, "tags": [["t", "general"], ["e", "root", "", "root", "alice"], ["p", "alice"]] }
    },
    {
      "name": "top-level comment on a task is NIP-22 kind 1111",
      "channels": ["dev"],
      "reply": {
        "parent": { "id": "t1", "pubkey": "alice", "kind": 1621 },
        "root": { "id": "t1", "pubkey": "alice", "kind": 1621 },
        "relayHint": "wss://one.example/"
      },
      "expected": {
        "kind": 1111,
        "tags": [
          ["t", "dev"],
          ["E", "t1", "wss://one.example/", "alice"],
          ["K", "1621"],
          ["P", "alice"],
          ["e", "t1", "wss://one.example/", "alice"],
          ["k", "1621"],
          ["p", "alice"]
        ]
      }
    },
    {
      "name": "top-level comment on an addressable calendar event carries A plus a and e",
      "channels": ["team"],
      "reply": {
        "parent": { "id": "c1", "pubkey": "alice", "kind": 31922, "address": "31922:alice:offsite" },
        "root": { "id": "c1", "pubkey": "alice", "kind": 31922, "address": "31922:alice:offsite" },
        "relayHint": "wss://one.example/"
      },
      "expected": {
        "kind": 1111,
        "tags": [
          ["t", "team"],
          ["A", "31922:alice:offsite", "wss://one.example/"],
          ["K", "31922"],
          ["P", "alice"],
          ["a", "31922:alice:offsite", "wss://one.example/"],
          ["e", "c1", "wss://one.example/", "alice"],
          ["k", "31922"],
          ["p", "alice"]
        ]
      }
    },
    {
      "name": "reply to a comment keeps the original root scope",
      "channels": ["dev"],
      "reply": {
        "parent": { "id": "r1", "pubkey": "bob", "kind": 1111 },
        "root": { "id": "t1", "pubkey": "alice", "kind": 1621 }
      },
      "expected": {
        "kind": 1111,
        "tags": [
          ["t", "dev"],
          ["E", "t1", "", "alice"],
          ["K", "1621"],
          ["P", "alice"],
          ["e", "r1", "", "bob"],
          ["k", "1111"],
          ["p", "bob"]
        ]
      }
    },
    {
      "name": "a comment still needs at least one channel",
      "channels": [],
      "reply": {
        "parent": { "id": "t1", "pubkey": "alice", "kind": 1621 },
        "root": { "id": "t1", "pubkey": "alice", "kind": 1621 }
      },
      "expected": { "error": "error.needChannel" }
    }
  ],
  "resolveTargetRelays": [
    {
      "name": "targets every connected space that delivered the post",
      "targetRelayIds": ["one-example", "two-example"],
      "expected": { "relayIds": ["one-example", "two-example"] }
    },
    {
      "name": "disconnected and unknown delivery spaces are skipped",
      "targetRelayIds": ["two-example", "three-example", "gone-example"],
      "expected": { "relayIds": ["two-example"] }
    },
    {
      "name": "no reachable delivery space errors",
      "targetRelayIds": ["three-example", "gone-example"],
      "expected": { "error": "error.postSpaceUnavailable" }
    }
  ],
  "buildReactionTags": [
    {
      "name": "reaction tags carry target with hint, author p-tag and kind k-tag",
      "target": { "id": "root", "pubkey": "alice", "kind": 1 },
      "relayHint": "wss://one.example/",
      "expected": { "tags": [["e", "root", "wss://one.example/", "alice"], ["p", "alice"], ["k", "1"]] }
    },
    {
      "name": "task reaction carries the task kind and an empty hint slot",
      "target": { "id": "t1", "pubkey": "bob", "kind": 1621 },
      "expected": { "tags": [["e", "t1", "", "bob"], ["p", "bob"], ["k", "1621"]] }
    }
  ],
  "buildDeletionTags": [
    {
      "name": "deletion carries an e-tag plus the target kind as k-tag",
      "targets": [{ "id": "m1", "kind": 1 }],
      "expected": { "tags": [["e", "m1"], ["k", "1"]] }
    },
    {
      "name": "multiple targets list every e-tag and dedupe k-tags",
      "targets": [{ "id": "r1", "kind": 7 }, { "id": "r2", "kind": 7 }],
      "expected": { "tags": [["e", "r1"], ["e", "r2"], ["k", "7"]] }
    }
  ]
}
