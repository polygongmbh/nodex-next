{
  "relayUrls": [
    "wss://one.example/",
    "wss://two.example/"
  ],
  "scenarios": [
    {
      "name": "duplicate delivery unions relay attribution",
      "steps": [
        {
          "event": {
            "id": "m1",
            "pubkey": "alice",
            "kind": 1,
            "content": "hi #dev",
            "tags": [],
            "created_at": 100
          },
          "relayUrl": "wss://one.example/"
        },
        {
          "event": {
            "id": "m1",
            "pubkey": "alice",
            "kind": 1,
            "content": "hi #dev",
            "tags": [],
            "created_at": 100
          },
          "relayUrl": "wss://two.example/"
        }
      ],
      "expected": {
        "posts": {
          "m1": {
            "relays": [
              "one-example",
              "two-example"
            ]
          }
        }
      }
    },
    {
      "name": "event without delivering relay is dropped",
      "steps": [
        {
          "event": {
            "id": "m1",
            "pubkey": "alice",
            "kind": 1,
            "content": "hi #dev",
            "tags": [],
            "created_at": 100
          },
          "relayUrl": null
        }
      ],
      "expected": {
        "absentPosts": [
          "m1"
        ]
      }
    },
    {
      "name": "re-ingest keeps folded state while adding attribution",
      "steps": [
        {
          "event": {
            "id": "t1",
            "pubkey": "alice",
            "kind": 1621,
            "content": "task #dev",
            "tags": [],
            "created_at": 100
          },
          "relayUrl": "wss://one.example/"
        },
        {
          "event": {
            "id": "s1",
            "pubkey": "alice",
            "kind": 1631,
            "content": "",
            "tags": [
              [
                "e",
                "t1"
              ]
            ],
            "created_at": 200
          },
          "relayUrl": "wss://one.example/"
        },
        {
          "event": {
            "id": "t1",
            "pubkey": "alice",
            "kind": 1621,
            "content": "task #dev",
            "tags": [],
            "created_at": 100
          },
          "relayUrl": "wss://two.example/"
