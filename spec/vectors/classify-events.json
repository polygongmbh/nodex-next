    {
      "name": "imeta tags become attachments",
      "event": {
        "id": "m7",
        "pubkey": "alice",
        "kind": 1,
        "content": "photo #dev",
        "tags": [
          [
            "imeta",
            "url https://x.example/a.png",
            "m image/png",
            "x hash123",
            "size 42"
          ],
          [
            "imeta",
            "url https://x.example/b.mp4",
            "m video/mp4"
          ]
        ],
        "created_at": 100
      },
      "relayIds": [
        "relay-a"
      ],
      "expected": {
        "type": "post",
        "attachments": [
          {
            "url": "https://x.example/a.png",
            "mimeType": "image/png",
            "sha256": "hash123",
            "size": 42
          },
          {
            "url": "https://x.example/b.mp4",
            "mimeType": "video/mp4"
          }
        ]
      }
    },
