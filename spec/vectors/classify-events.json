{
  "cases": [
    {
      "name": "kind 1 message with union channels and attribution",
      "event": {
        "id": "m1",
        "pubkey": "alice",
        "kind": 1,
        "content": "ship it #general",
        "tags": [
          [
            "t",
            "launch"
          ]
        ],
        "created_at": 100
      },
      "relayIds": [
        "relay-a"
      ],
      "expected": {
        "type": "post",
        "channels": [
          "general",
          "launch"
        ],
        "relays": [
          "relay-a"
        ],
        "parentId": null,
        "mentions": []
      }
    },
    {
      "name": "parent marker preferred over reply",
      "event": {
        "id": "m2",
        "pubkey": "alice",
        "kind": 1,
        "content": "re #dev",
        "tags": [
          [
            "e",
            "other",
            "",
            "reply"
          ],
          [
            "e",
            "root",
            "",
            "parent"
          ]
        ],
        "created_at": 100
      },
      "relayIds": [
        "relay-a"
      ],
      "expected": {
        "type": "post",
        "parentId": "root"
      }
    },
    {
      "name": "reply marker used when no parent marker",
      "event": {
        "id": "m3",
        "pubkey": "alice",
        "kind": 1,
        "content": "re #dev",
        "tags": [
          [
            "e",
            "root",
            "",
            "reply"
          ]
        ],
        "created_at": 100
      },
      "relayIds": [
        "relay-a"
      ],
      "expected": {
        "type": "post",
        "parentId": "root"
      }
    },
    {
      "name": "unmarked e-tag is not a parent",
      "event": {
