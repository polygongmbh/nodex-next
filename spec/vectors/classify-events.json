    {
      "name": "time-based calendar event parsed",
      "event": {
        "id": "c1",
        "pubkey": "alice",
        "kind": 31923,
        "content": "Weekly sync",
        "tags": [
          [
            "d",
            "standup"
          ],
          [
            "title",
            "Standup"
          ],
          [
            "start",
            "1751900400"
          ],
          [
            "end",
            "1751904000"
          ],
          [
            "location",
            "Jitsi"
          ],
          [
            "t",
            "dev"
          ]
        ],
        "created_at": 100
      },
      "relayIds": [
        "relay-a"
      ],
      "expected": {
        "type": "calendarEvent",
        "calendar": {
          "d": "standup",
          "title": "Standup",
          "start": "1751900400",
          "end": "1751904000",
          "location": "Jitsi",
          "channels": [
            "dev"
          ],
          "kind": 31923
        }
      }
    },
