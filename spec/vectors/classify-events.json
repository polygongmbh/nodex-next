          ],
          [
            "E",
            "id-b"
          ],
          [
            "k",
            "1"
          ]
        ],
        "created_at": 300
      },
      "relayIds": [
        "relay-a"
      ],
      "expected": {
        "type": "deletion",
        "byPubkey": "alice",
