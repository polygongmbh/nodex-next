    {
      "name": "kind 7 plus-content reaction normalizes to thumbs up",
      "event": {
        "id": "r1",
        "pubkey": "bob",
        "kind": 7,
        "content": "+",
        "tags": [["e", "m1", "", "alice"], ["p", "alice"], ["k", "1"]],
        "created_at": 100
      },
      "relayIds": ["relay-a"],
      "expected": { "type": "reaction", "targetId": "m1", "emoji": "👍", "reactionPubkey": "bob", "relays": ["relay-a"] }
    },
    {
      "name": "kind 7 empty content also counts as thumbs up",
      "event": {
        "id": "r2",
        "pubkey": "bob",
        "kind": 7,
        "content": "",
        "tags": [["e", "m1"]],
        "created_at": 100
      },
      "relayIds": ["relay-a"],
      "expected": { "type": "reaction", "targetId": "m1", "emoji": "👍" }
    },
    {
      "name": "kind 7 minus content normalizes to thumbs down",
      "event": {
        "id": "r3",
        "pubkey": "bob",
        "kind": 7,
        "content": "-",
        "tags": [["e", "m1"]],
        "created_at": 100
      },
      "relayIds": ["relay-a"],
      "expected": { "type": "reaction", "targetId": "m1", "emoji": "👎" }
    },
    {
      "name": "kind 7 single emoji passes through",
      "event": {
        "id": "r4",
        "pubkey": "bob",
        "kind": 7,
        "content": "🎉",
        "tags": [["e", "m1"]],
        "created_at": 100
      },
      "relayIds": ["relay-a"],
      "expected": { "type": "reaction", "targetId": "m1", "emoji": "🎉" }
    },
    {
      "name": "kind 7 skin-tone emoji is one grapheme and passes through",
      "event": {
        "id": "r5",
        "pubkey": "bob",
        "kind": 7,
        "content": "👍🏽",
        "tags": [["e", "m1"]],
        "created_at": 100
      },
      "relayIds": ["relay-a"],
      "expected": { "type": "reaction", "targetId": "m1", "emoji": "👍🏽" }
    },
    {
      "name": "kind 7 reacts to the LAST e-tag per NIP-25",
      "event": {
        "id": "r6",
        "pubkey": "bob",
        "kind": 7,
        "content": "+",
        "tags": [["e", "root"], ["e", "m2"], ["p", "alice"]],
        "created_at": 100
      },
      "relayIds": ["relay-a"],
      "expected": { "type": "reaction", "targetId": "m2", "emoji": "👍" }
    },
    {
      "name": "kind 7 word content is not a reaction",
      "event": {
        "id": "r7",
        "pubkey": "bob",
        "kind": 7,
        "content": "nice",
        "tags": [["e", "m1"]],
        "created_at": 100
      },
      "relayIds": ["relay-a"],
      "expected": { "type": "ignored" }
    },
    {
      "name": "kind 7 shortcode content is not a reaction (no NIP-30)",
      "event": {
        "id": "r8",
        "pubkey": "bob",
        "kind": 7,
        "content": ":fire:",
        "tags": [["e", "m1"]],
        "created_at": 100
      },
      "relayIds": ["relay-a"],
      "expected": { "type": "ignored" }
    },
    {
      "name": "kind 7 lone ascii character is not a reaction",
      "event": {
        "id": "r9",
        "pubkey": "bob",
        "kind": 7,
        "content": "x",
        "tags": [["e", "m1"]],
        "created_at": 100
      },
      "relayIds": ["relay-a"],
      "expected": { "type": "ignored" }
    },
    {
      "name": "kind 7 without any e-tag is ignored",
      "event": {
        "id": "r10",
        "pubkey": "bob",
        "kind": 7,
        "content": "+",
        "tags": [["p", "alice"]],
        "created_at": 100
      },
      "relayIds": ["relay-a"],
      "expected": { "type": "ignored" }
    },
    {
      "name": "kind 1111 comment threads under its lowercase e-tag parent",
      "event": {
        "id": "cm1",
        "pubkey": "bob",
        "kind": 1111,
        "content": "looks good #dev",
        "tags": [
          ["E", "t1", "", "alice"],
          ["K", "1621"],
          ["P", "alice"],
          ["e", "t1", "", "alice"],
          ["k", "1621"],
          ["p", "alice"]
        ],
        "created_at": 100
      },
      "relayIds": ["relay-a"],
      "expected": { "type": "post", "kind": 1111, "parentId": "t1", "channels": ["dev"], "relays": ["relay-a"] }
    },
    {
      "name": "kind 1111 nested comment parents on the lowercase e, not the root E",
      "event": {
        "id": "cm2",
        "pubkey": "carol",
        "kind": 1111,
        "content": "re #dev",
        "tags": [
          ["E", "t1", "", "alice"],
          ["K", "1621"],
          ["P", "alice"],
          ["e", "cm1", "", "bob"],
          ["k", "1111"],
          ["p", "bob"]
        ],
        "created_at": 100
      },
      "relayIds": ["relay-a"],
      "expected": { "type": "post", "kind": 1111, "parentId": "cm1" }
    },
    {
      "name": "kind 1111 comment on an addressable event still parents on its e-tag",
      "event": {
        "id": "cm3",
        "pubkey": "bob",
        "kind": 1111,
        "content": "see you there #team",
        "tags": [
          ["A", "31922:alice:offsite", ""],
          ["K", "31922"],
          ["P", "alice"],
          ["a", "31922:alice:offsite", ""],
          ["e", "c1", "", "alice"],
          ["k", "31922"],
          ["p", "alice"]
        ],
        "created_at": 100
      },
      "relayIds": ["relay-a"],
      "expected": { "type": "post", "kind": 1111, "parentId": "c1" }
    },
    {
      "name": "kind 1111 without a lowercase e-tag parent is ignored",
      "event": {
        "id": "cm4",
        "pubkey": "bob",
        "kind": 1111,
        "content": "external scope",
        "tags": [
          ["I", "https://abc.example/article"],
          ["K", "web"],
          ["i", "https://abc.example/article"],
          ["k", "web"]
        ],
        "created_at": 100
      },
      "relayIds": ["relay-a"],
      "expected": { "type": "ignored" }
    }
  ]
}
