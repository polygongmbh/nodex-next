# Deployment config for the nodex-next stack (Traefik / Docker Swarm).
#
# NOTE: this is NOT the app's build-time config. The Vite build bakes VITE_*
# from a `.env` at the repo root (see ../.env.example) when `docker build`
# runs. This file only drives `docker stack deploy` / abra.
#
# Usage:
#   abra:        abra copies this to ~/.abra/servers/<server>/<domain>.env on
#                `abra app new`; edit via `abra app config <domain>`.
#   plain swarm: copy to deploy/.env, then run ./deploy/deploy.sh

# Recipe name — must match the recipe/stack (abra: required, = recipe name).
TYPE=nodex-next

# Domains served by this instance. Comma-separated, NO Traefik syntax.
# ./deploy/deploy.sh expands this into Host(`a`) || Host(`b`) and uses the
# first entry as the canonical DOMAIN.
DOMAINS=nodex.example.com

# abra is single-domain per app: it sets DOMAIN from `abra app new <domain>`,
# and the compose rule falls back to Host(`$DOMAIN`). For abra multi-domain,
# set ROUTER_RULE explicitly here:
#DOMAIN=nodex.example.com
#ROUTER_RULE=Host(`nodex.example.com`) || Host(`app.example.org`)

# Traefik cert resolver from the Co-op Cloud traefik recipe: production|staging
LETS_ENCRYPT_ENV=production

# Stack/router name. abra sets this automatically from the app; only needed
# for manual docker stack deploy.
STACK_NAME=nodex-next

# Image to deploy. abra ALWAYS pulls from a registry (it never builds), and a
# multi-node swarm needs one too. Single-node manual deploys can use a locally
# built tag.
IMAGE=nodex-next:latest
