# Co-op Cloud app env. With abra this lives at
# ~/.abra/servers/<server>/<domain>.env; for manual `docker stack deploy`,
# copy to deploy/.env and source it before deploying.
TYPE=nodex-next
DOMAIN=nodex.example.com

# Traefik cert resolver as configured in the Co-op Cloud traefik recipe:
# "production" or "staging".
LETS_ENCRYPT_ENV=production

# Stack name used in Traefik router/service names. abra sets this itself;
# for manual deploys keep it equal to the stack name you pass to
# `docker stack deploy`.
STACK_NAME=nodex-next

# Image to deploy. Override with your registry tag when the swarm has
# multiple nodes (a locally built image is only visible on the build node).
IMAGE=nodex-next:latest
