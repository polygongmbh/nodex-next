# Nodex Next — build-time configuration (Vite). Copy to `.env` and adjust.

# Default noas host for plain usernames (no @domain). A `user@domain` username
# always picks its own host and ignores this.
VITE_NOAS_HOST_URL=nodex.nexus

# Subdomains probed under the noas host's root domain when neither the account
# nor noas discovery supplies a space (comma-separated, priority order). The
# first reachable `wss://<subdomain>.<root>` is adopted. Leave unset for the
# default: tasks,feed,relay,nostr.
VITE_SPACE_PROBE_SUBDOMAINS=tasks,feed,relay,nostr
